<% content_for :title, "Perfil — #{@profile_user.username}" %>
<% content_for :page_title, @profile_user.username.upcase %>
<% content_for :head do %>
  <link rel="stylesheet" href="/css/profiles.css">
<% end %>

<div class="profile-header">
  <% if @profile_user.avatar_url.present? %>
    <img src="<%= @profile_user.avatar_url %>" class="profile-avatar" alt="<%= @profile_user.username %>">
  <% else %>
    <div class="profile-avatar-placeholder"><%= @profile_user.username[0].upcase %></div>
  <% end %>
  <div class="profile-info">
    <h1><%= @profile_user.username %></h1>
    <div class="subtitle"><%= @race_history.size %> carrera<%= @race_history.size == 1 ? "" : "s" %> completada<%= @race_history.size == 1 ? "" : "s" %></div>
  </div>
</div>

<div class="section-title">Caballos favoritos</div>
<% available_horses = Horse.all.reject { |h| @my_favorites.include?(h.id) }.first(5) %>
<%= render "horse_favorites/section",
    favorites: @favorites,
    is_own_profile: @is_own_profile,
    query: "",
    search_results: (@is_own_profile ? available_horses : []),
    favorited_all: (@is_own_profile ? @my_favorites.size >= Horse.count : false) %>

<div class="section-title">Historial de carreras</div>

<% if @race_history.empty? %>
  <p class="empty-note">Aún no hay carreras en el historial.</p>
<% else %>
  <table class="history-table">
    <thead>
      <tr>
        <th>Sala</th>
        <th>Mi caballo</th>
        <th>Resultado</th>
        <th>Ganador</th>
        <th>Fecha</th>
      </tr>
    </thead>
    <tbody>
      <% @race_history.each do |p| %>
        <% won = p.race.winner_name == p.horse_name %>
        <tr>
          <td><span class="race-slug"><%= p.race.slug %></span></td>
          <td><span class="horse-name"><%= p.horse_name %></span></td>
          <td>
            <% if won %>
              <span class="result-win">🏆 Ganador</span>
            <% else %>
              <span class="result-loss">💀 Perdedor</span>
            <% end %>
          </td>
          <td><%= p.race.winner_name %></td>
          <td class="race-date"><%= p.race.finished_at.strftime("%d/%m/%Y %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
