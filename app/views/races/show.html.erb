<% content_for :title, "Horse Race — #{@race.slug}" %>
<% content_for :page_title, @race.slug.upcase %>
<% content_for :head do %>
  <link rel="stylesheet" href="/css/race-lobby.css">
<% end %>

<div data-controller="race-lobby"
     data-race-lobby-race-id-value="<%= @race.id %>"
     data-race-lobby-race-slug-value="<%= @race.slug %>"
     data-race-lobby-animal-type-value="<%= @race.animal_type %>"
     data-race-lobby-capacity-value="<%= @race.capacity %>"
     data-race-lobby-participant-count-value="<%= @participants.size %>"
     data-race-lobby-favorite-ids-value="<%= @favorite_horse_ids.to_json %>">

  <div class="lobby-header">
    <h1><%= @race.animal_type == "guinea_pig" ? "🐹" : "🐴" %> <%= @race.slug %></h1>
    <div class="players-count" data-race-lobby-target="playersCount">
      <%= @participants.size %>/<%= @race.capacity %> jugadores
    </div>
  </div>

  <div class="share-row">
    <input type="text" id="share-link" readonly value="<%= request.base_url %>/races/<%= @race.slug %>">
    <button data-action="click->race-lobby#copyLink">Copiar</button>
  </div>

  <div class="section-title">Participantes</div>
  <div id="participants-list" data-race-lobby-target="participantsList">
    <% @participants.each do |p| %>
      <div class="participant-row" id="participant-<%= p.id %>">
        <span class="p-username"><%= p.display_name %></span>
        <span class="p-horse">🐎 <%= p.horse_name %></span>
        <% if p.user_id.present? %>
          <button class="profile-btn"
                  data-action="click->race-lobby#openProfilePopup"
                  data-username="<%= p.user.username %>"
                  title="Ver perfil">👤</button>
        <% end %>
      </div>
    <% end %>
  </div>

  <div id="profile-overlay"
       data-race-lobby-target="profileOverlay"
       data-action="click->race-lobby#closeProfilePopup">
    <div id="profile-popup" data-race-lobby-target="profilePopup">
      <button class="pp-close" data-action="click->race-lobby#closePopupBtn">✕</button>
      <div class="pp-header">
        <div data-race-lobby-target="ppAvatarWrap"></div>
        <div>
          <div class="pp-username" data-race-lobby-target="ppUsername"></div>
          <a class="pp-link" data-race-lobby-target="ppProfileLink" href="#">Ver perfil completo →</a>
        </div>
      </div>
      <div class="pp-stats">
        <div>
          <div class="pp-stat-val" data-race-lobby-target="ppRaces">—</div>
          <div class="pp-stat-lbl">Carreras</div>
        </div>
        <div>
          <div class="pp-stat-val" data-race-lobby-target="ppWins">—</div>
          <div class="pp-stat-lbl">Victorias</div>
        </div>
      </div>
      <div class="pp-favs-title">Caballos favoritos</div>
      <div class="pp-favs" data-race-lobby-target="ppFavs"></div>
    </div>
  </div>

  <% if @my_participant.nil? %>
    <div id="horse-picker" data-race-lobby-target="horsePicker">
      <h2>Elige tu caballo</h2>
      <div id="picker-cards" class="picker-cards" data-race-lobby-target="pickerCards">
        <% hue_rotations = [0, 55, 110, 170, 220, 285] %>
        <% @available_horses.each_with_index do |horse, i| %>
          <% is_fav = @favorite_horse_ids.include?(horse.id) %>
          <div class="picker-card<%= is_fav ? ' favorite' : '' %>"
               data-horse-id="<%= horse.id %>"
               data-action="click->race-lobby#pickHorse">
            <img src="/images/<%= @race.animal_type %>/frame_1.png"
                 style="filter: hue-rotate(<%= hue_rotations[i % hue_rotations.size] %>deg)">
            <div class="card-name"><%= is_fav ? '⭐ ' : '' %><%= horse.name %></div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div id="status-bar" data-race-lobby-target="statusBar">
    <% remaining = @race.capacity - @participants.size %>
    <% if remaining > 0 %>
      Esperando <%= remaining %> jugador<%= remaining == 1 ? "" : "es" %> más…
    <% else %>
      ¡Sala lista!
    <% end %>
  </div>

  <% if @is_creator && @race.pending? %>
    <div id="apostador-section" data-race-lobby-target="apostadorSection">
      <h3>Agregar apostador</h3>
      <input id="apostador-name-input" type="text" placeholder="Nombre del apostador (ej. Juan)">
      <div id="apostador-cards" class="picker-cards">
        <% hue_rotations = [0, 55, 110, 170, 220, 285] %>
        <% @all_available_horses.each_with_index do |horse, i| %>
          <div class="picker-card"
               id="apostador-card-<%= horse.id %>"
               data-horse-id="<%= horse.id %>"
               data-action="click->race-lobby#addApostador">
            <img src="/images/<%= @race.animal_type %>/frame_1.png"
                 style="filter: hue-rotate(<%= hue_rotations[i % hue_rotations.size] %>deg)">
            <div class="card-name"><%= horse.name %></div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @race.creator_id == current_user.id %>
    <button id="btn-start"
            data-race-lobby-target="btnStart"
            data-action="click->race-lobby#startRace">🏁 Comenzar carrera</button>
  <% end %>

  <div id="race-section" data-race-lobby-target="raceSection">
    <div id="countdown" data-race-lobby-target="countdown"></div>
    <div id="track" data-race-lobby-target="track"></div>
    <div id="winner-banner" data-race-lobby-target="winnerBanner"></div>
  </div>

  <div class="back-link"><%= link_to "← Volver a salas", root_path %></div>

</div>
