<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Horse Race — Nueva sala</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, sans-serif;
      background: #1a1a2e;
      color: #eee;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    h1 { font-size: 2rem; margin-bottom: 0.25rem; }
    .subtitle { color: #888; margin-bottom: 2rem; font-size: 0.9rem; }

    .card {
      background: #16213e;
      border: 1px solid #2a2a4a;
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 420px;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .field { display: flex; flex-direction: column; gap: 0.4rem; }
    label { font-size: 0.85rem; color: #aaa; font-weight: 600; }

    input[type="text"], select {
      width: 100%;
      padding: 0.6rem 0.9rem;
      background: #0f0f23;
      border: 1px solid #2a2a4a;
      border-radius: 8px;
      color: #eee;
      font-size: 1rem;
    }
    input[type="text"]:focus, select:focus {
      outline: none;
      border-color: #4f46e5;
    }
    select option { background: #0f0f23; }

    .toggle-row {
      display: flex; align-items: center; justify-content: space-between;
    }
    .toggle-label { font-size: 0.85rem; color: #aaa; font-weight: 600; }
    .toggle {
      position: relative; width: 44px; height: 24px;
    }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
      position: absolute; inset: 0;
      background: #2a2a4a; border-radius: 24px;
      cursor: pointer; transition: background 0.2s;
    }
    .toggle-slider::before {
      content: ""; position: absolute;
      height: 18px; width: 18px; left: 3px; bottom: 3px;
      background: #eee; border-radius: 50%;
      transition: transform 0.2s;
    }
    .toggle input:checked + .toggle-slider { background: #4f46e5; }
    .toggle input:checked + .toggle-slider::before { transform: translateX(20px); }

    .error-list {
      background: #450a0a;
      border: 1px solid #b91c1c;
      color: #fca5a5;
      border-radius: 8px;
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .btn-submit {
      width: 100%;
      padding: 0.65rem 1rem;
      background: #4f46e5; color: #fff;
      border: none; border-radius: 8px;
      font-size: 1rem; cursor: pointer;
      transition: opacity 0.2s;
    }
    .btn-submit:hover { opacity: 0.85; }

    .back-link {
      text-align: center;
      font-size: 0.85rem;
    }
    .back-link a { color: #6366f1; text-decoration: none; }
    .back-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <h1>🏇 Nueva sala</h1>
  <p class="subtitle">Configurá tu carrera multijugador</p>

  <%= form_with model: @race, url: races_path, method: :post, class: "card" do |f| %>

    <% if @race.errors.any? %>
      <ul class="error-list">
        <% @race.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="field">
      <%= f.label :slug, "Nombre de sala (slug)" %>
      <%= f.text_field :slug, placeholder: "swift-fox-42" %>
    </div>

    <div class="field">
      <%= f.label :capacity, "Capacidad" %>
      <%= f.select :capacity, (2..12).map { |n| [n, n] }, {}, {} %>
    </div>

    <div class="field">
      <%= f.label :animal_type, "Tipo de animal" %>
      <%= f.select :animal_type, [["🐴 Caballos", "horse"], ["🐹 Cobayas", "guinea_pig"]] %>
    </div>

    <div class="toggle-row">
      <span class="toggle-label">Sala pública</span>
      <label class="toggle">
        <%= f.check_box :is_public, { checked: @race.is_public != false }, "1", "0" %>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <%= f.submit "Crear sala", class: "btn-submit" %>

    <div class="back-link">
      <%= link_to "← Volver a salas", root_path %>
    </div>

  <% end %>

</body>
</html>
