<% content_for :title, "Horse Race — Salas" %>
<% content_for :page_title, "SALAS" %>
<% content_for :head do %>
  <link rel="stylesheet" href="/css/races-list.css">
<% end %>

<div class="header-row">
  <h2>Salas abiertas</h2>
  <%= link_to "＋ CREAR", new_race_path, class: "btn-primary" %>
</div>

<div class="rooms-grid">
  <% if @races.empty? %>
    <p class="empty-state">No hay salas abiertas. ¡Creá la primera!</p>
  <% else %>
    <% @races.each do |race| %>
      <div class="room-card">
        <span class="animal-emoji"><%= race.animal_type == "guinea_pig" ? "🐹" : "🐴" %></span>
        <div class="room-info">
          <div class="room-slug"><%= race.slug %></div>
          <div class="room-meta">Creado por <%= race.creator&.username || "anónimo" %></div>
        </div>
        <div class="room-right">
          <div class="room-players"><%= race.participants.size %>/<%= race.capacity %></div>
          <%= link_to "UNIRSE", race_path(race), class: "btn-join" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
