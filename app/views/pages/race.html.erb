<% content_for :title, "Horse Race" %>
<% content_for :head do %>
  <link rel="stylesheet" href="/css/race-page.css">
<% end %>

<div data-controller="race-page">

  <h1>Horse Race</h1>
  <p class="subtitle">WebSocket powered</p>

  <div id="horse-picker" data-race-page-target="horsePicker">
    <h2>Elige tu caballo</h2>
    <div id="picker-timer-wrap">
      <div id="picker-timer-bar">
        <div id="picker-timer-fill" data-race-page-target="timerFill"></div>
      </div>
      <span id="picker-timer-text" data-race-page-target="timerText">10 segundos para elegir</span>
    </div>
    <div id="picker-cards" class="picker-cards" data-race-page-target="pickerCards"></div>
  </div>

  <div id="animal-selector" style="display:none" data-race-page-target="animalSelector"></div>

  <div id="controls" style="display:none" data-race-page-target="controls">
    <button id="btn-new" data-race-page-target="btnNew" data-action="click->race-page#newRace">Nueva carrera</button>
    <button id="btn-start" data-race-page-target="btnStart" data-action="click->race-page#startRace" disabled>Iniciar</button>
    <span id="status-text" data-race-page-target="statusText">Sin carrera</span>
  </div>

  <div id="track" data-race-page-target="track"></div>
  <div id="winner-banner" data-race-page-target="winnerBanner"></div>

</div>
