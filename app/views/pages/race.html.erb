<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Horse Race</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #1a1a2e;
      color: #eee;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem 1rem;
    }

    h1 { font-size: 2rem; margin-bottom: 0.25rem; }
    .subtitle { color: #888; margin-bottom: 2rem; font-size: 0.9rem; }

    #controls { margin-bottom: 2rem; display: flex; gap: 1rem; align-items: center; }

    button {
      padding: 0.6rem 1.5rem;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    button:disabled { opacity: 0.4; cursor: not-allowed; }

    #btn-new   { background: #4f46e5; color: #fff; }
    #btn-start { background: #16a34a; color: #fff; }

    #status-text { font-size: 0.9rem; color: #aaa; }

    #track {
      width: 100%;
      max-width: 720px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .lane {
      background: #16213e;
      border-radius: 8px;
      padding: 0.75rem 1rem;
    }

    .lane-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.4rem;
      font-size: 0.9rem;
    }

    .horse-name { font-weight: 600; }
    .horse-pct  { color: #888; }

    .progress-bg {
      background: #0f3460;
      border-radius: 999px;
      height: 20px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      border-radius: 999px;
      width: 0%;
      transition: width 0.25s ease-out;
    }

    #winner-banner {
      display: none;
      margin-top: 2rem;
      background: #854d0e;
      border: 2px solid #fbbf24;
      border-radius: 12px;
      padding: 1.25rem 2rem;
      text-align: center;
      font-size: 1.4rem;
      font-weight: 700;
      color: #fef3c7;
    }
  </style>
</head>
<body>

  <h1>Horse Race</h1>
  <p class="subtitle">WebSocket powered</p>

  <div id="controls">
    <button id="btn-new">Nueva carrera</button>
    <button id="btn-start" disabled>Iniciar</button>
    <span id="status-text">Sin carrera</span>
  </div>

  <div id="track"></div>
  <div id="winner-banner"></div>

<script>
  const COLORS = ["#6366f1","#ec4899","#f59e0b","#10b981","#3b82f6","#ef4444"];

  let raceId   = null;
  let socket   = null;

  const btnNew   = document.getElementById("btn-new");
  const btnStart = document.getElementById("btn-start");
  const statusEl = document.getElementById("status-text");
  const trackEl  = document.getElementById("track");
  const bannerEl = document.getElementById("winner-banner");

  function setStatus(text) { statusEl.textContent = text; }

  function renderTrack(horses) {
    trackEl.innerHTML = horses.map(function(h, i) {
      return '<div class="lane" id="lane-' + h.id + '">' +
        '<div class="lane-header">' +
          '<span class="horse-name">' + h.name + '</span>' +
          '<span class="horse-pct" id="pct-' + h.id + '">0%</span>' +
        '</div>' +
        '<div class="progress-bg">' +
          '<div class="progress-fill" id="bar-' + h.id + '" style="background:' + COLORS[i % COLORS.length] + '"></div>' +
        '</div>' +
      '</div>';
    }).join("");
  }

  function updatePositions(participants) {
    participants.forEach(function(p) {
      var bar = document.getElementById("bar-" + p.id);
      var pct = document.getElementById("pct-" + p.id);
      if (bar) bar.style.width = p.position + "%";
      if (pct) pct.textContent = Math.round(p.position) + "%";
    });
  }

  // Action Cable protocol over native WebSocket
  function connectToRace(id) {
    if (socket) socket.close();

    var wsUrl = (location.protocol === "https:" ? "wss:" : "ws:") + "//" + location.host + "/cable";
    socket = new WebSocket(wsUrl);

    var identifier = JSON.stringify({ channel: "RaceChannel", race_id: id });

    socket.onopen = function() {
      socket.send(JSON.stringify({ command: "subscribe", identifier: identifier }));
    };

    socket.onmessage = function(event) {
      var msg = JSON.parse(event.data);

      // Ignore protocol-level messages
      if (msg.type === "welcome" || msg.type === "ping" || msg.type === "confirm_subscription") return;

      var data = msg.message;
      if (!data) return;

      if (data.type === "progress") {
        updatePositions(data.participants);
      } else if (data.type === "finished") {
        bannerEl.textContent = "Ganador: " + data.winner.name;
        bannerEl.style.display = "block";
        setStatus("Carrera terminada");
        btnNew.disabled = false;
        btnStart.disabled = true;
        socket.close();
      }
    };

    socket.onerror = function(e) {
      setStatus("Error de conexion WebSocket");
    };
  }

  btnNew.addEventListener("click", function() {
    btnNew.disabled = true;
    btnStart.disabled = true;
    bannerEl.style.display = "none";
    setStatus("Creando carrera...");

    fetch("/races", { method: "POST", headers: { "Content-Type": "application/json" } })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        raceId = data.id;
        return fetch("/races/" + raceId);
      })
      .then(function(res) { return res.json(); })
      .then(function(raceData) {
        renderTrack(raceData.horses);
        connectToRace(raceId);
        setStatus("Carrera #" + raceId + " lista");
        btnStart.disabled = false;
      })
      .catch(function(err) {
        setStatus("Error: " + err.message);
        btnNew.disabled = false;
      });
  });

  btnStart.addEventListener("click", function() {
    btnStart.disabled = true;
    btnNew.disabled = true;
    setStatus("Corriendo...");

    fetch("/races/" + raceId + "/start", { method: "POST" })
      .catch(function(err) {
        setStatus("Error al iniciar: " + err.message);
      });
  });
</script>
</body>
</html>
