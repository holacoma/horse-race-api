<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Horse Race</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #1a1a2e;
      color: #eee;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem 1rem;
    }

    h1 { font-size: 2rem; margin-bottom: 0.25rem; }
    .subtitle { color: #888; margin-bottom: 2rem; font-size: 0.9rem; }

    #controls {
      margin-bottom: 2rem;
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    button {
      padding: 0.6rem 1.5rem;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    button:disabled { opacity: 0.4; cursor: not-allowed; }
    #btn-new   { background: #4f46e5; color: #fff; }
    #btn-start { background: #16a34a; color: #fff; }
    #status-text { font-size: 0.9rem; color: #aaa; }

    /* ── Track ── */
    #track {
      width: 100%;
      max-width: 820px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .lane-row {
      display: flex;
      align-items: flex-end;
      gap: 10px;
    }

    .lane-label {
      width: 80px;
      font-size: 0.78rem;
      font-weight: 600;
      text-align: right;
      flex-shrink: 0;
      color: #ccc;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      /* align label with the track surface */
      padding-bottom: 10px;
    }

    /*
     * track-wrap: the full lane area, including the space above the
     * dirt surface where the horse body sits.
     */
    .track-wrap {
      flex: 1;
      position: relative;
      height: 132px; /* 2× sprite height so the horse is never clipped */
    }

    /* dirt + grass strip — sits at the bottom of the wrapper */
    .track-bg {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 44px;
      background: #a0784a;
      border-top: 7px solid #3d6b35;
      border-bottom: 7px solid #3d6b35;
      overflow: hidden; /* clips the pseudo-element decorations only */
      border-radius: 3px;
    }

    /* subtle vertical dirt lines */
    .track-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        90deg,
        transparent,
        transparent 40px,
        rgba(0,0,0,0.07) 40px,
        rgba(0,0,0,0.07) 41px
      );
    }

    /* checkered finish line on the right edge */
    .track-bg::before {
      content: "";
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 10px;
      background: repeating-linear-gradient(
        180deg,
        #fff 0px, #fff 6px,
        #000 6px, #000 12px
      );
      z-index: 2;
    }

    /*
     * Horse sprite — sibling of track-bg, NOT a child, so overflow:hidden
     * on track-bg doesn't clip it.
     */
    .horse-sprite {
      position: absolute;
      bottom: 0;         /* sits on the track surface */
      left: 0;
      width: 164px;      /* 2× original 82 px */
      height: 132px;     /* 2× original 66 px */
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      transform: scaleX(-1); /* face right */
      transition: left 0.28s linear;
      z-index: 1;
    }

    /* ── Winner banner ── */
    #winner-banner {
      display: none;
      margin-top: 2rem;
      background: #854d0e;
      border: 2px solid #fbbf24;
      border-radius: 12px;
      padding: 1.25rem 2.5rem;
      text-align: center;
      font-size: 1.5rem;
      font-weight: 700;
      color: #fef3c7;
      animation: pop 0.3s ease-out;
    }

    @keyframes pop {
      from { transform: scale(0.8); opacity: 0; }
      to   { transform: scale(1);   opacity: 1; }
    }

    /* ── Selector de animal ── */
    #animal-selector {
      margin-bottom: 1.5rem;
    }
    #animal-selector select {
      padding: 0.5rem 1rem;
      border: 2px solid #4f46e5;
      border-radius: 8px;
      background: #2a2a4a;
      color: #fff;
      font-size: 1rem;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <h1>Horse Race</h1>
  <p class="subtitle">WebSocket powered</p>

  <div id="animal-selector"></div>

  <div id="controls">
    <button id="btn-new">Nueva carrera</button>
    <button id="btn-start" disabled>Iniciar</button>
    <span id="status-text">Sin carrera</span>
  </div>

  <div id="track"></div>
  <div id="winner-banner"></div>

<script>
  var HUE_ROTATIONS = [0, 55, 110, 170, 220, 285];
  var FRAME_COUNT   = 5;
  var FRAME_RATE_MS = 110;

  var frameIndex    = 0;
  var animInterval  = null;
  var raceId        = null;
  var socket        = null;
  var selectedAnimal = "guinea_pig";

  // Para agregar un nuevo animal: añadir una entrada aquí. Nada más.
  var ANIMALS = {
    horse: {
      label: "Caballos", emoji: "🐴",
      frameCount: 5,
      createElement: function(id, hue) {
        return '<img class="horse-sprite" id="horse-' + id + '"' +
               ' src="/images/horse/frame_1.png"' +
               ' style="filter: hue-rotate(' + hue + 'deg)">';
      },
      updateFrame: function(el, i) {
        el.src = "/images/horse/frame_" + (i + 1) + ".png";
      }
    },
    guinea_pig: {
      label: "Cobayas", emoji: "🐹",
      frameCount: 4,
      createElement: function(id, hue) {
        return '<img class="horse-sprite" id="horse-' + id + '"' +
               ' src="/images/guinea_pig/frame_1.png"' +
               ' style="transform: scaleX(1); height: auto; filter: hue-rotate(' + hue + 'deg)">';
      },
      updateFrame: function(el, i) {
        el.src = "/images/guinea_pig/frame_" + (i + 1) + ".png";
      }
    }
  };

  var btnNew      = document.getElementById("btn-new");
  var btnStart    = document.getElementById("btn-start");
  var statusEl    = document.getElementById("status-text");
  var trackEl     = document.getElementById("track");
  var bannerEl    = document.getElementById("winner-banner");
  var selectorEl  = document.getElementById("animal-selector");

  function setStatus(text) { statusEl.textContent = text; }

  selectorEl.innerHTML = '<select id="animal-select">' +
    Object.keys(ANIMALS).map(function(key) {
      var a = ANIMALS[key];
      return '<option value="' + key + '">' + a.emoji + ' ' + a.label + '</option>';
    }).join('') +
  '</select>';

  var animalSelect = document.getElementById("animal-select");
  animalSelect.value = selectedAnimal;
  animalSelect.addEventListener("change", function() {
    selectedAnimal = this.value;
  });

  function renderTrack(horses) {
    trackEl.innerHTML = horses.map(function(h, i) {
      var hue = HUE_ROTATIONS[i % HUE_ROTATIONS.length];
      return (
        '<div class="lane-row">' +
          '<span class="lane-label">' + h.name + '</span>' +
          '<div class="track-wrap" id="wrap-' + h.id + '">' +
            '<div class="track-bg"></div>' +
            ANIMALS[selectedAnimal].createElement(h.id, hue) +
          '</div>' +
        '</div>'
      );
    }).join("");
  }

  function startAnimation() {
    if (animInterval) return;
    var cfg = ANIMALS[selectedAnimal];
    animInterval = setInterval(function() {
      frameIndex = (frameIndex + 1) % cfg.frameCount;
      document.querySelectorAll(".horse-sprite").forEach(function(el) {
        cfg.updateFrame(el, frameIndex);
      });
    }, FRAME_RATE_MS);
  }

  function stopAnimation() {
    clearInterval(animInterval);
    animInterval = null;
  }

  function moveHorse(horseId, position) {
    var img  = document.getElementById("horse-" + horseId);
    var wrap = document.getElementById("wrap-" + horseId);
    if (!img || !wrap) return;
    // use wrap width so the horse stops just before the finish line
    var maxLeft = wrap.offsetWidth - img.offsetWidth;
    img.style.left = Math.max(0, position / 100 * maxLeft) + "px";
  }

  function connectToRace(id) {
    if (socket) socket.close();

    var wsUrl = (location.protocol === "https:" ? "wss:" : "ws:") +
                "//" + location.host + "/cable";
    socket = new WebSocket(wsUrl);

    var identifier = JSON.stringify({ channel: "RaceChannel", race_id: id });

    socket.onopen = function() {
      socket.send(JSON.stringify({ command: "subscribe", identifier: identifier }));
    };

    socket.onmessage = function(event) {
      var msg = JSON.parse(event.data);
      if (msg.type === "welcome" || msg.type === "ping" || msg.type === "confirm_subscription") return;

      var data = msg.message;
      if (!data) return;

      if (data.type === "progress") {
        data.participants.forEach(function(p) { moveHorse(p.id, p.position); });
      } else if (data.type === "finished") {
        stopAnimation();
        bannerEl.textContent = "Ganador: " + data.winner.name;
        bannerEl.style.display = "block";
        setStatus("Carrera terminada");
        btnNew.disabled = false;
        selectorEl.style.display = "flex";
        socket.close();
      }
    };

    socket.onerror = function() { setStatus("Error de conexion WebSocket"); };
  }

  btnNew.addEventListener("click", function() {
    btnNew.disabled = true;
    btnStart.disabled = true;
    selectorEl.style.display = "none";
    bannerEl.style.display = "none";
    stopAnimation();
    frameIndex = 0;
    setStatus("Creando carrera...");

    fetch("/races", { method: "POST", headers: { "Content-Type": "application/json" } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        raceId = data.id;
        return fetch("/races/" + raceId);
      })
      .then(function(r) { return r.json(); })
      .then(function(raceData) {
        renderTrack(raceData.horses);
        connectToRace(raceId);
        setStatus("Carrera #" + raceId + " lista");
        btnStart.disabled = false;
      })
      .catch(function(err) {
        setStatus("Error: " + err.message);
        btnNew.disabled = false;
        selectorEl.style.display = "flex";
      });
  });

  btnStart.addEventListener("click", function() {
    btnStart.disabled = true;
    btnNew.disabled = true;
    startAnimation();
    setStatus("Corriendo...");

    fetch("/races/" + raceId + "/start", { method: "POST" })
      .catch(function(err) {
        setStatus("Error al iniciar: " + err.message);
        stopAnimation();
      });
  });
</script>
</body>
</html>
